{
  "name": "jk-bms-victron-dashboard",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "vue-tsc -b --noEmit",
    "check": "npm run typecheck && npm test",
    "check:visual": "node scripts/visual-check.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/saira-semi-condensed": "^5.2.7",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "puppeteer-core": "^25.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.5"
  },
  "description": "Read a JK-BMS and a Victron SmartSolar over Bluetooth from the browser, and derive DC-bus house load without a shunt",
